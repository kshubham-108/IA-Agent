# IA Agent — environment variables (copy to .env.local and fill in)
#
# Where each app reads secrets:
#   agent/     → agent/.env.local   (eve dev / eve start)
#   apps/web/  → apps/web/.env.local
#   bakeoff, eval:live, pnpm calibrate → repo root .env.local (this directory)
#
# See https://vercel.com/docs/ai-gateway for AI_GATEWAY_API_KEY.

# Vercel AI Gateway API key (required for live models, bakeoff, eval:live)
AI_GATEWAY_API_KEY=

# Stage 1 — classify_documents (cheap tier; default: google/gemini-2.5-flash)
MODEL_CLASSIFY=google/gemini-2.5-flash

# Stage 2 — extract / estimate (quality tier; default: anthropic/claude-sonnet-4.6)
MODEL_EXTRACT=google/gemini-2.5-pro

# Set to 1 to run Eve evals with the mock model (CI / offline). Omit for live runs.
# EVE_MOCK_MODEL=1
