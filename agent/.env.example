# Eve agent — copy to .env.local in this directory (eve dev reads agent/.env.local)
#
# Get a key: https://vercel.com/docs/ai-gateway
# Or run `eve dev` and use the TUI provider menu to save AI_GATEWAY_API_KEY here.

# Vercel AI Gateway API key (required for live agent sessions)
AI_GATEWAY_API_KEY=

# Stage 1 — classify_documents (cheap tier)
MODEL_CLASSIFY=google/gemini-3.5-flash-lite

# Stage 2 — extract / estimate (quality tier)
MODEL_EXTRACT=google/gemini-3.6-flash

# Uncomment to force mock model locally (eval scripts set this automatically)
EVE_MOCK_MODEL=1
